# Copy this file to .env and replace the placeholder values.

PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-string

# OIDC issuer for your Cognito User Pool:
# https://cognito-idp.<aws-region>.amazonaws.com/<user-pool-id>
COGNITO_ISSUER=https://cognito-idp.ap-northeast-1.amazonaws.com/ap-northeast-1_xxxxxxxxx

# App client settings from Cognito
COGNITO_CLIENT_ID=your-cognito-app-client-id
COGNITO_CLIENT_SECRET=your-cognito-app-client-secret

# Cognito Hosted UI domain, without /login or /logout path
# Example: your-domain.auth.ap-northeast-1.amazoncognito.com
COGNITO_DOMAIN=your-domain.auth.ap-northeast-1.amazoncognito.com
