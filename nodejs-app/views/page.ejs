<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %> | <%= appInfo.name %></title>
    <style>
        :root {
            --shell-bg: <%= theme.shellBackground %>;
            --panel-bg: <%= theme.panelBackground %>;
            --panel-border: <%= theme.panelBorder %>;
            --accent: <%= theme.accent %>;
            --accent-soft: <%= theme.accentSoft %>;
            --text: <%= theme.text %>;
            --muted: <%= theme.muted %>;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text);
            background: var(--shell-bg);
            min-height: 100vh;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .page {
            width: min(1100px, calc(100% - 32px));
            margin: 0 auto;
            padding: 32px 0 48px;
        }

        .hero,
        .panel {
            background: rgba(255, 255, 255, 0.58);
            border: 1px solid var(--panel-border);
            border-radius: 28px;
            padding: 26px;
            box-shadow: 0 18px 40px rgba(0, 0, 0, 0.07);
        }

        .hero-top,
        .panel-top {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            gap: 16px;
            align-items: flex-start;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            min-height: 34px;
            padding: 0 12px;
            border-radius: 999px;
            background: var(--accent-soft);
            color: var(--accent);
            font-size: 0.88rem;
            font-weight: 700;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        h1, h2 {
            margin: 12px 0 8px;
        }

        p, li {
            color: var(--muted);
            line-height: 1.6;
        }

        .nav,
        .subnav,
        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .subnav {
            margin-top: 18px;
        }

        .nav-link,
        .subnav-link,
        .cta {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 42px;
            padding: 0 16px;
            border-radius: 999px;
            border: 1px solid var(--panel-border);
            background: rgba(255, 255, 255, 0.72);
        }

        .nav-link.current,
        .subnav-link.current,
        .cta.primary {
            background: var(--accent);
            border-color: var(--accent);
            color: white;
            font-weight: 700;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 18px;
            margin-top: 22px;
        }

        .kpis {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 12px;
            margin-top: 18px;
        }

        .kpi {
            padding: 14px;
            border-radius: 18px;
            background: rgba(255, 255, 255, 0.7);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .kpi strong {
            display: block;
            margin-bottom: 6px;
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .mono {
            font-family: Consolas, "Courier New", monospace;
            font-size: 0.94rem;
            color: var(--text);
            word-break: break-word;
        }

        .actions {
            margin-top: 18px;
        }

        pre {
            margin: 0;
            padding: 18px;
            border-radius: 18px;
            background: #172026;
            color: #f1f5f9;
            overflow: auto;
        }
    </style>
</head>
<body>
    <div class="page">
        <section class="hero">
            <div class="hero-top">
                <div>
                    <span class="eyebrow"><%= pageEyebrow %></span>
                    <h1><%= pageTitle %></h1>
                    <p><%= pageSummary %></p>
                </div>
                <nav class="nav" aria-label="App switcher">
                    <% navigationApps.forEach((navApp) => { %>
                        <a class="nav-link <%= navApp.isCurrent ? 'current' : '' %>" href="<%= navApp.url %>"><%= navApp.name %></a>
                    <% }) %>
                </nav>
            </div>

            <nav class="subnav" aria-label="Route switcher">
                <% pageLinks.forEach((link) => { %>
                    <a class="subnav-link <%= link.current ? 'current' : '' %>" href="<%= link.href %>"><%= link.label %></a>
                <% }) %>
            </nav>

            <div class="actions">
                <a class="cta" href="/">Back to Home</a>
                <% if (isAuthenticated) { %>
                    <a class="cta primary" href="/logout">Logout from <%= appInfo.name %></a>
                <% } else { %>
                    <a class="cta primary" href="/login">Login with Cognito</a>
                <% } %>
            </div>
        </section>

        <section class="grid">
            <article class="panel">
                <h2>Access Rules</h2>
                <div class="kpis">
                    <div class="kpi">
                        <strong>Route</strong>
                        <div class="mono"><%= pageLinks.find((link) => link.current).href %></div>
                    </div>
                    <div class="kpi">
                        <strong>Access mode</strong>
                        <div class="mono"><%= accessMode %></div>
                    </div>
                    <div class="kpi">
                        <strong>Session state</strong>
                        <div class="mono"><%= isAuthenticated ? 'Authenticated' : 'Anonymous' %></div>
                    </div>
                </div>

                <% bodySections.forEach((section) => { %>
                    <div>
                        <h2><%= section.heading %></h2>
                        <% section.paragraphs.forEach((paragraph) => { %>
                            <p><%= paragraph %></p>
                        <% }) %>
                    </div>
                <% }) %>
            </article>

            <article class="panel">
                <h2>Route Details</h2>
                <ul>
                    <% detailItems.forEach((item) => { %>
                        <li><strong><%= item.label %>:</strong> <%= item.value %></li>
                    <% }) %>
                </ul>
            </article>
        </section>

        <section class="grid">
            <article class="panel">
                <h2>App Context</h2>
                <div class="kpis">
                    <div class="kpi">
                        <strong>Base URL</strong>
                        <div class="mono"><%= appInfo.baseUrl %></div>
                    </div>
                    <div class="kpi">
                        <strong>Callback URL</strong>
                        <div class="mono"><%= appInfo.redirectUri %></div>
                    </div>
                    <div class="kpi">
                        <strong>App Client ID</strong>
                        <div class="mono"><%= appInfo.clientId %></div>
                    </div>
                </div>
            </article>

            <article class="panel">
                <h2>Session Snapshot</h2>
                <% if (isAuthenticated) { %>
                    <pre><%= JSON.stringify(userInfo, null, 2) %></pre>
                <% } else { %>
                    <p>No local session exists in this app yet.</p>
                    <p>Use the login button above or open the protected page to trigger the Cognito flow.</p>
                <% } %>
            </article>
        </section>
    </div>
</body>
</html>
